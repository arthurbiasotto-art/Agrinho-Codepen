<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sustentabilidade Inteligente - Global Hub Ultra</title>
  
  <style>
    /* 1. CONFIGURAÇÕES GERAIS E PALETA DE CORES */
    :root {
      --bg-color: #020617;
      --card-bg: #0f172a;
      --primary: #00ffaa;
      --secondary: #0ea5e9;
      --accent: #f43f5e;
      --text: #f8fafc;
      --text-muted: #94a3b8;
      --border: rgba(0, 255, 170, 0.2);
    }

    * { 
      box-sizing: border-box; 
      margin: 0; 
      padding: 0; 
      font-family: 'Segoe UI', system-ui, sans-serif; 
    }

    body {
      background-color: var(--bg-color);
      color: var(--text);
      min-height: 100vh;
      padding: 2rem 1rem;
      background-image: 
        radial-gradient(at 0% 0%, rgba(0, 255, 170, 0.07) 0px, transparent 50%),
        radial-gradient(at 100% 100%, rgba(14, 165, 233, 0.07) 0px, transparent 50%);
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    header { 
      text-align: center; 
      margin-bottom: 2.5rem; 
      max-width: 900px; 
    }

    h1 { 
      font-size: 3.5rem; 
      font-weight: 900; 
      background: linear-gradient(to right, var(--primary), var(--secondary)); 
      -webkit-background-clip: text; 
      -webkit-text-fill-color: transparent; 
      letter-spacing: -2px; 
      margin-bottom: 0.5rem;
    }

    header p {
      color: var(--text-muted);
      font-size: 1.2rem;
      margin-bottom: 1.5rem;
    }

    /* Imagem de Banner Central */
    .banner-img {
      width: 100%;
      max-width: 1200px;
      border-radius: 20px;
      border: 1px solid var(--border);
      box-shadow: 0 15px 40px rgba(0, 255, 170, 0.1);
      margin-bottom: 2.5rem;
    }

    /* SISTEMA DE ABAS (TABS) */
    .tabs-nav {
      display: flex;
      gap: 1rem;
      margin-bottom: 2rem;
      background: rgba(255, 255, 255, 0.03);
      padding: 0.5rem;
      border-radius: 16px;
      border: 1px solid var(--border);
    }

    .tab-btn {
      background: transparent;
      border: none;
      color: var(--text-muted);
      padding: 0.8rem 1.5rem;
      border-radius: 12px;
      cursor: pointer;
      font-weight: 700;
      font-size: 1rem;
      transition: all 0.3s;
    }

    .tab-btn.active { 
      background: var(--primary); 
      color: var(--bg-color); 
      box-shadow: 0 0 20px rgba(0, 255, 170, 0.4); 
    }

    /* CONTÊINERES DAS ABAS */
    .tab-content { 
      display: none; 
      width: 100%; 
      max-width: 1200px; 
      animation: fadeIn 0.4s ease; 
    }

    .tab-content.active { 
      display: grid; 
      grid-template-columns: 1fr; 
      gap: 2rem; 
    }

    @media (min-width: 1024px) {
      .tab-content.active { grid-template-columns: 1.35fr 0.65fr; }
    }

    .card {
      background: var(--card-bg);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 2.5rem;
      box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
      height: fit-content;
    }

    @keyframes fadeIn { 
      from { opacity: 0; transform: translateY(10px); } 
      to { opacity: 1; transform: translateY(0); } 
    }

    /* ESTILO DOS ARTIGOS DE TEXTO */
    .article-body h2 { font-size: 2rem; margin-bottom: 1.5rem; color: #fff; border-bottom: 1px solid rgba(255,255,255,0.05); padding-bottom: 0.5rem; }
    .article-body h3 { color: var(--primary); margin: 2.5rem 0 1rem; font-size: 1.4rem; }
    .article-body p { line-height: 1.8; color: var(--text-muted); margin-bottom: 1.5rem; font-size: 1.1rem; }
    .highlight-card { background: rgba(14, 165, 233, 0.08); border-radius: 16px; padding: 1.5rem; border: 1px solid var(--secondary); margin: 2rem 0; }
    .quote-box { background: rgba(0, 255, 170, 0.03); border-left: 4px solid var(--primary); padding: 1.25rem; border-radius: 0 12px 12px 0; margin: 1.5rem 0; font-style: italic; }

    /* JOGO 1: ECO-GRID */
    .game-box-core {
      background: #050a18;
      border: 1px solid rgba(0, 210, 255, 0.2);
      border-radius: 16px;
      padding: 2rem;
      text-align: center;
    }

    .stats-panel-row {
      display: flex;
      justify-content: space-around;
      margin-bottom: 1.5rem;
      background: rgba(255, 255, 255, 0.03);
      padding: 1rem;
      border-radius: 12px;
    }

    .stat-block-unit span {
      display: block;
      font-size: 1.8rem;
      font-weight: bold;
      color: var(--primary);
    }

    .btn-grid-actions {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }

    .btn-interactive-click {
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #fff;
      padding: 1rem;
      border-radius: 12px;
      cursor: pointer;
      font-weight: 700;
      font-size: 1rem;
      transition: all 0.2s;
    }

    .btn-interactive-click:hover {
      background: var(--secondary);
      color: var(--bg-color);
      transform: translateY(-2px);
    }

    /* JOGO 2: ECO-TRUNFO */
    .card-game-deck-view {
      background: #050a18;
      border: 1px solid rgba(254, 63, 94, 0.2);
      border-radius: 16px;
      padding: 2rem;
      text-align: center;
    }

    .molecular-card-item {
      background: linear-gradient(145deg, #111e3d, #070d1d);
      border: 2px solid var(--secondary);
      border-radius: 18px;
      padding: 1.5rem;
      margin: 1.5rem auto;
      max-width: 280px;
      box-shadow: 0 15px 30px rgba(0,0,0,0.6);
    }

    .attribute-clickable-row {
      display: flex;
      justify-content: space-between;
      margin: 0.6rem 0;
      padding: 0.5rem;
      background: rgba(255,255,255,0.03);
      border-radius: 8px;
      cursor: pointer;
      font-size: 0.95rem;
      transition: 0.2s;
    }

    .attribute-clickable-row:hover {
      background: rgba(0, 255, 170, 0.15);
      border-left: 3px solid var(--primary);
    }

    .btn-primary-action {
      background: linear-gradient(135deg, var(--primary), var(--secondary));
      color: #020617;
      border: none;
      padding: 1rem 1.5rem;
      font-weight: 800;
      border-radius: 12px;
      cursor: pointer;
      width: 100%;
      text-transform: uppercase;
    }

    /* ABA 3: LABORATÓRIO DE POLÍTICAS */
    .policy-selection-grid { 
      display: grid; 
      grid-template-columns: 1fr 1fr; 
      gap: 1.2rem; 
    }
    
    .policy-toggle-button {
      background: rgba(255,255,255,0.03);
      border: 1px solid rgba(255,255,255,0.1);
      padding: 1.2rem;
      border-radius: 14px;
      cursor: pointer;
      text-align: left;
      color: #fff;
      font-weight: 600;
      font-size: 1rem;
      transition: 0.2s;
    }
    
    .policy-toggle-button.active { 
      border-color: var(--primary); 
      background: rgba(0, 255, 170, 0.06); 
    }
    
    .planet-impact-dashboard { 
      margin-top: 2rem; 
      background: #000; 
      padding: 1.5rem; 
      border-radius: 16px; 
    }
    
    .progress-meter-container { 
      height: 12px; 
      background: #1e293b; 
      border-radius: 6px; 
      margin: 12px 0; 
      overflow: hidden; 
    }
    
    .progress-meter-fill { 
      height: 100%; 
      width: 50%; 
      background: var(--primary); 
      transition: 0.6s cubic-bezier(0.4, 0, 0.2, 1); 
    }

    /* TERMINAL DE LOGS */
    .terminal-log-box {
      background: #000;
      border: 1px solid #1e293b;
      border-radius: 12px;
      padding: 1rem;
      font-family: 'Courier New', monospace;
      font-size: 0.85rem;
      color: #00ffaa;
      height: 150px;
      overflow-y: auto;
      margin-top: 1rem;
    }
  </style>
</head>
<body>

  <header>
    <h1>Sustentabilidade Inteligente</h1>
    <p>O Sistema Operacional da Biosfera: Tecnologia, Ética e Engenharia Planetária.</p>
  </header>

  <img src="http://googleusercontent.com/image_generation_content/0" alt="Painel Global Hub de Sustentabilidade" class="banner-img">

  <nav class="tabs-nav">
    <button class="tab-btn active" onclick="switchTabSystem(event, 'aba-artigos-texto')">📖 Artigos & Visões</button>
    <button class="tab-btn" onclick="switchTabSystem(event, 'aba-central-jogos')">🎮 Laboratório de Jogos</button>
    <button class="tab-btn" onclick="switchTabSystem(event, 'aba-simulador-politicas')">🔬 Matriz de Políticas</button>
  </nav>

  <div id="aba-artigos-texto" class="tab-content active">
    <main class="card article-body">
      <h2>O Manifesto da Civilização Ecológica Cognitiva</h2>
      <p>A transição para a sustentabilidade inteligente exige que abandonemos o modelo arcaico de encarar a natureza de forma passiva. As metrópoles do futuro operam sob o conceito de infraestrutura integrada, onde sensores físicos, redes de dados e biologia molecular coexistem em simbiose perfeita.</p>
      
      <div class="quote-box">
        "O desperdício e a poluição não são consequências inevitáveis do progresso, são apenas falhas de design e erros de cálculo algorítmico."
      </div>

      <h3>1. A Internet das Plantas e Fungos (The Wood Wide Web)</h3>
      <p>Pesquisas avançadas em bio-informática revelam que os sistemas de micélio subterrâneo funcionam como uma infraestrutura de dados complexa na natureza. No ecossistema inteligente, aprendemos a interagir amigavelmente com essa rede. Nano-sensores injetados em corredores florestais captam alterações químicas nas raízes, alertando sistemas centrais sobre estresse hídrico ou contaminações antes que as plantas manifestem danos físicos.</p>

      <h3>2. Biomimética Estrutural e Materiais Vivos</h3>
      <p>A arquitetura civil moderna funde biologia com concreto. Novos compostos utilizam matrizes fúngicas integradas com bactérias calcificantes. Quando fissuras microscópicas aparecem em estruturas urbanas devido ao desgaste, a entrada de humidade ativa estes microrganismos. Eles digerem compostos químicos e expelem calcário organicamente, selando as rachaduras sem intervenção humana.</p>

      <div class="highlight-card">
        <strong>Georreferenciamento de Carbono:</strong> Através de livros de registro distribuídos (blockchains verdes), distritos residenciais gerenciam créditos ambientais em tempo real. O oxigênio purificado por fachadas vivas é tokenizado e financia autonomamente a expansão energética dos bairros periféricos.
      </div>

      <h3>3. Iluminação Fotoluminescente Descentralizada</h3>
      <p>Ao isolar enzimas de luciferase encontradas em organismos marinhos e aplicá-las na seiva de árvores urbanas por edição genética controlada, engenheiros criaram calçadas biológicas. Essas plantas emitem um brilho natural suave durante a noite, reduzindo severamente a necessidade de postes de luz elétricos tradicionais.</p>
    </main>

    <aside class="card">
      <h2 style="font-size: 1.3rem; margin-bottom: 1rem;">Glossário de Inovação</h2>
      <p style="font-size: 0.95rem; margin-bottom: 1rem;"><strong>• Bio-Digital Twin:</strong> Cópias virtuais planetárias que processam dados meteorológicos em tempo real para prever desastres ecológicos.</p>
      <p style="font-size: 0.95rem; margin-bottom: 1rem;"><strong>• Economia Regenerativa:</strong> Modelos comerciais onde o lucro corporativo está indexado à quantidade de recursos recuperados e devolvidos limpos à natureza.</p>
      <p style="font-size: 0.95rem;"><strong>• Upcycling Molecular:</strong> Despoluição automatizada utilizando nano-robôs projetados para quebrar polímeros de microplásticos em rios.</p>
    </aside>
  </div>

  <div id="aba-central-jogos" class="tab-content">
    <main class="card">
      <h2>🎮 Jogo 1: Simulador Eco-Grid</h2>
      <p style="color: var(--text-muted); margin-bottom: 1.5rem;">Monitore as redes e mantenha o equilíbrio ecológico urbano antes do colapso térmico!</p>
      
      <div class="game-box-core">
        <div class="stats-panel-row">
          <div class="stat-block-unit">Qualidade do Ar<span id="grid-ar-display">100%</span></div>
          <div class="stat-block-unit">Bateria Urbana<span id="grid-en-display" style="color: var(--secondary);">80</span></div>
        </div>
        <div class="btn-grid-actions">
          <button class="btn-interactive-click" onclick="executeGridLogic('floresta')">🌿 Plantar Floresta</button>
          <button class="btn-interactive-click" onclick="executeGridLogic('bateria')">⚡ Ativar Fusão Tech</button>
        </div>
        <p id="grid-system-alert" style="margin-top: 1.5rem; font-size: 0.9rem; color: var(--text-muted); font-style: italic;">Sistema operacional ativo. Aguardando comandos.</p>
      </div>
    </main>

    <aside class="card">
      <h2>🃏 Jogo 2: Eco-Trunfo Molecular</h2>
      <p style="color: var(--text-muted); margin-bottom: 1rem;">Escolha o melhor atributo do seu projeto sustentável para vencer o algoritmo oponente!</p>
      
      <div class="card-game-deck-view">
        <div class="molecular-card-item">
          <h3 id="trunfo-card-title" style="color: var(--primary); font-size: 1.2rem; margin-bottom: 0.75rem;">Filtro de Microalgas</h3>
          <div class="attribute-clickable-row" onclick="triggerCardDuel('impacto')">🌱 Impacto Ecológico: <span id="val-attr-imp">98</span></div>
          <div class="attribute-clickable-row" onclick="triggerCardDuel('tech')">⚡ Nível Tecnológico: <span id="val-attr-tech">80</span></div>
          <div class="attribute-clickable-row" onclick="triggerCardDuel('custo')">💰 Custo de Patente: <span id="val-attr-cost">50</span></div>
        </div>
        <p id="trunfo-duel-logs" style="font-size: 0.9rem; color: var(--secondary); font-weight: bold;">Sua vez! Selecione um atributo para duelar.</p>
        <button class="btn-primary-action" style="margin-top: 1rem; display:none;" id="btn-reset-trunfo-card" onclick="loadNextTrunfoCard()">Próxima Patente</button>
      </div>
    </aside>
  </div>

  <div id="aba-simulador-politicas" class="tab-content">
    <main class="card">
      <h2>🔬 Laboratório de Políticas Planetárias</h2>
      <p style="margin-bottom: 1.5rem; color: var(--text-muted);">Ative diretrizes governamentais e observe a resposta mecânica direta nos marcadores climáticos globais.</p>
      <div class="policy-selection-grid">
        <button class="policy-toggle-button" onclick="evaluatePolicyChanges(this, -0.5, 20, 'Fusão Quântica')">⚛️ Redes de Fusão Quântica</button>
        <button class="policy-toggle-button" onclick="evaluatePolicyChanges(this, -0.3, 15, 'Dieta Bio-Sintética')">🥗 Dieta Global Bio-Sintética</button>
        <button class="policy-toggle-button" onclick="evaluatePolicyChanges(this, -0.8, 30, 'Mineração Espacial')">🛰️ Mineração de Asteroides</button>
        <button class="policy-toggle-button" onclick="evaluatePolicyChanges(this, -1.2, 50, 'Reflorestamento')">🌳 Reflorestamento Autônomo</button>
      </div>
      
      <h3 style="font-size: 1.1rem; margin-top: 2rem; margin-bottom: 0.5rem; color: #fff;">Logs do Console de Comando:</h3>
      <div class="terminal-log-box" id="terminal-logs">
        [SYSTEM] Aguardando ativação de diretrizes macroecológicas...
      </div>
    </main>

    <aside class="card">
      <h2>📊 Status da Biosfera</h2>
      
      <div class="planet-impact-dashboard">
        <p style="font-size: 0.9rem; color: var(--text-muted);">Temperatura Global</p>
        <div class="progress-meter-container">
          <div id="fill-temp-progress" class="progress-meter-fill" style="width: 85%; background: var(--accent);"></div>
        </div>
        <p id="label-temp-status" style="font-size: 1.4rem; font-weight: bold; color: var(--accent);">+2.5°C</p>
      </div>

      <div class="planet-impact-dashboard" style="margin-top: 1.5rem;">
        <p style="font-size: 0.9rem; color: var(--text-muted);">Índice de Biodiversidade</p>
        <div class="progress-meter-container">
          <div id="fill-bio-progress" class="progress-meter-fill" style="width: 30%; background: var(--primary);"></div>
        </div>
        <p id="label-bio-status" style="font-size: 1.4rem; font-weight: bold; color: var(--primary);">30%</p>
      </div>
    </aside>
  </div>

  <script>
    /* ENGINE DE NAVEGAÇÃO ENTRE ABAS */
    function switchTabSystem(eventRef, targetedTabId) {
      document.querySelectorAll('.tab-content').forEach(element => element.classList.remove('active'));
      document.querySelectorAll('.tab-btn').forEach(btn => btn.classList.remove('active'));
      
      document.getElementById(targetedTabId).classList.add('active');
      eventRef.currentTarget.classList.add('active');
    }

    /* ENGINE DO Jogo 1: ECO-GRID */
    let airMetrics = 100;
    let energyMetrics = 80;
    
    setInterval(() => {
      if(airMetrics > 0 && energyMetrics > 0) {
        airMetrics -= 3;
        energyMetrics -= 2;
        syncGridVisuals();
      }
    }, 2500);

    function executeGridLogic(type) {
      if (airMetrics <= 0 || energyMetrics <= 0) {
        airMetrics = 100; energyMetrics = 80;
        document.getElementById('grid-system-alert').style.color = "var(--text-muted)";
        syncGridVisuals();
        return;
      }

      if(type === 'floresta') {
        airMetrics = Math.min(airMetrics + 22, 100);
        energyMetrics = Math.max(energyMetrics - 12, 0);
        document.getElementById('grid-system-alert').innerText = "Bio-filtros expandidos! Qualidade do ar restaurada.";
      } else {
        energyMetrics = Math.min(energyMetrics + 25, 120);
        airMetrics = Math.max(airMetrics - 8, 0);
        document.getElementById('grid-system-alert').innerText = "Reatores ativos! Grade energética recarregada.";
      }
      syncGridVisuals();
    }

    function syncGridVisuals() {
      const arLabel = document.getElementById('grid-ar-display');
      const enLabel = document.getElementById('grid-en-display');
      
      arLabel.innerText = airMetrics + "%";
      enLabel.innerText = energyMetrics;

      arLabel.style.color = airMetrics < 35 ? "var(--accent)" : "var(--primary)";
      enLabel.style.color = energyMetrics < 25 ? "var(--accent)" : "var(--secondary)";

      if(airMetrics <= 0 || energyMetrics <= 0) {
        document.getElementById('grid-system-alert').innerText = "🚨 COLAPSO URBANO! Infraestrutura falhou. Clique em qualquer botão para reiniciar.";
        document.getElementById('grid-system-alert').style.color = "var(--accent)";
      }
    }

    /* ENGINE DO JOGO 2: ECO-TRUNFO */
    const trunfoDatabase = [
      {nome: "Painel de Grafeno", imp: 95, tech: 92, custo: 40},
      {nome: "Concreto Biogênico", imp: 88, tech: 75, custo: 20},
      {nome: "Filtro de Microalgas", imp: 98, tech: 80, custo: 50},
      {nome: "Reciclador Quântico", imp: 75, tech: 96, custo: 85}
    ];
    let currentActiveCard = trunfoDatabase[2];

    function triggerCardDuel(chosenAttr) {
      const adversaryBotCard = trunfoDatabase[Math.floor(Math.random() * trunfoDatabase.length)];
      
      let pVal = chosenAttr === 'impacto' ? currentActiveCard.imp : (chosenAttr === 'tech' ? currentActiveCard.tech : currentActiveCard.custo);
      let bVal = chosenAttr === 'impacto' ? adversaryBotCard.imp : (chosenAttr === 'tech' ? adversaryBotCard.tech : adversaryBotCard.custo);
      
      let playerVictory = false;
      if(chosenAttr === 'custo') {
        playerVictory = pVal < bVal;
      } else {
        playerVictory = pVal > bVal;
      }

      const logElement = document.getElementById('trunfo-duel-logs');
      if(playerVictory) {
        logElement.innerHTML = `🏆 Vitória! Seu oponente perdeu usando "${adversaryBotCard.nome}" (${bVal}).`;
        logElement.style.color = "var(--primary)";
      } else {
        logElement.innerHTML = `❌ Derrota! O bot superou você com "${adversaryBotCard.nome}" (${bVal}).`;
        logElement.style.color = "var(--accent)";
      }
      document.getElementById('btn-reset-trunfo-card').style.display = "block";
    }

    function loadNextTrunfoCard() {
      currentActiveCard = trunfoDatabase[Math.floor(Math.random() * trunfoDatabase.length)];
      document.getElementById('trunfo-card-title').innerText = currentActiveCard.nome;
      document.getElementById('val-attr-imp').innerText = currentActiveCard.imp;
      document.getElementById('val-attr-tech').innerText = currentActiveCard.tech;
      document.getElementById('val-attr-cost').innerText = currentActiveCard.custo;
      
      const logElement = document.getElementById('trunfo-duel-logs');
      logElement.innerText = "Sua vez! Selecione um atributo acima para iniciar o duelo.";
      logElement.style.color = "var(--secondary)";
      document.getElementById('btn-reset-trunfo-card').style.display = "none";
    }

    /* ENGINE DA ABA 3: LAB DE POLÍTICAS E TERMINAL DE LOGS */
    let dynamicGlobalTemp = 2.5;
    let dynamicGlobalBio = 30;

    function evaluatePolicyChanges(btnRef, tempModifier, bioModifier, policyName) {
      btnRef.classList.toggle('active');
      let isEnacted = btnRef.classList.contains('active');
      
      dynamicGlobalTemp += isEnacted ? tempModifier : -tempModifier;
      dynamicGlobalBio += isEnacted ? bioModifier : -bioModifier;

      dynamicGlobalTemp = Math.max(-0.5, dynamicGlobalTemp);
      dynamicGlobalBio = Math.min(100, Math.max(0, dynamicGlobalBio));

      // Atualiza o terminal de logs simulado
      const term = document.getElementById('terminal-logs');
      const timeString = new Date().toLocaleTimeString();
      const statusText = isEnacted ? "ATIVADA" : "DESATIVADA";
      term.innerHTML += `<br>[${timeString}] DIRETRIZ: "${policyName}" foi ${statusText}.`;
      term.scrollTop = term.scrollHeight; // Auto-scroll para baixo

      renderLabDashboard();
    }

    function renderLabDashboard() {
      const barTempFill = document.getElementById('fill-temp-progress');
      const barBioFill = document.getElementById('fill-bio-progress');
      
      let calculatedVisualScale = (dynamicGlobalTemp + 0.5) * 30;
      barTempFill.style.width = Math.min(100, Math.max(0, calculatedVisualScale)) + "%";
      barTempFill.style.background = dynamicGlobalTemp > 1.4 ? "var(--accent)" : "var(--primary)";
      
      document.getElementById('label-temp-status').innerText = dynamicGlobalTemp.toFixed(1) + "°C";
      document.getElementById('label-temp-status').style.color = dynamicGlobalTemp > 1.4 ? "var(--accent)" : "var(--primary)";

      barBioFill.style.width = dynamicGlobalBio + "%";
      document.getElementById('label-bio-status').innerText = dynamicGlobalBio + "%";
    }
  </script>
</body>
</html>
